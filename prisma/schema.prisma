generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  PLATFORM_ADMIN
  OPERATOR
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique(map: "uq_users_email")
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          Role
  isActive      Boolean   @default(false) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastLoginAt   DateTime? @map("last_login_at")
  deletedAt     DateTime? @map("deleted_at")
  accounts      Account[]
  sessions      Session[]
  students      Student[] @relation("OperatorStudents")

  @@map("users")
}

model OperatorAudit {
  id         String   @id @default(cuid())
  operatorId String   @map("operator_id")
  actorId    String   @map("actor_id")
  action     String
  summary    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([operatorId, createdAt(sort: Desc)], map: "ix_operator_audit_operator")
  @@map("operator_audit")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([provider, providerAccountId])
  @@index([userId], map: "ix_accounts_user")
  @@map("accounts")
}

model Session {
  sessionToken String   @id @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "ix_sessions_user")
  @@index([expires], map: "ix_sessions_expires")
  @@map("sessions")
}

model Student {
  id           String        @id
  name         String
  createdAt    DateTime      @default(now()) @map("created_at")
  operatorId   String        @map("operator_id")
  operator     User          @relation("OperatorStudents", fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  transactions Transaction[]

  @@index([operatorId], map: "ix_students_operator")
  @@map("students")
}

model Transaction {
  id        String   @id
  studentId String   @map("student_id")
  type      String
  amount    BigInt
  createdAt DateTime @default(now()) @map("created_at")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([studentId, createdAt(sort: Desc), id(sort: Desc)], map: "ix_transactions_student_history")
  @@map("transactions")
}
