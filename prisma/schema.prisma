generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  PLATFORM_ADMIN
  OPERATOR
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CORRECTION
}

enum CorrectionDirection {
  INCREASE
  DECREASE
}

enum FinancialAuditEventType {
  CREATE
  EDIT
  DELETE
  RESTORE
  OWNERSHIP_TRANSFER
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique(map: "uq_users_email")
  emailVerified        DateTime?             @map("email_verified")
  image                String?
  role                 Role
  isActive             Boolean               @default(false) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  lastLoginAt          DateTime?             @map("last_login_at")
  deletedAt            DateTime?             @map("deleted_at")
  accounts             Account[]
  sessions             Session[]
  students             Student[]             @relation("OperatorStudents")
  createdTransactions  Transaction[]         @relation("TransactionCreator")
  updatedTransactions  Transaction[]         @relation("TransactionUpdater")
  deletedTransactions  Transaction[]         @relation("TransactionDeleter")
  financialAuditEvents FinancialAuditEvent[] @relation("FinancialAuditActor")

  @@map("users")
}

model OperatorAudit {
  id         String   @id @default(cuid())
  operatorId String   @map("operator_id")
  actorId    String   @map("actor_id")
  action     String
  summary    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([operatorId, createdAt(sort: Desc)], map: "ix_operator_audit_operator")
  @@map("operator_audit")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([provider, providerAccountId])
  @@index([userId], map: "ix_accounts_user")
  @@map("accounts")
}

model Session {
  sessionToken String   @id @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "ix_sessions_user")
  @@index([expires], map: "ix_sessions_expires")
  @@map("sessions")
}

model Student {
  id                   String                @id
  name                 String
  notes                String?
  status               StudentStatus         @default(ACTIVE)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  operatorId           String                @map("operator_id")
  operator             User                  @relation("OperatorStudents", fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  transactions         Transaction[]
  financialAuditEvents FinancialAuditEvent[]
  balance              BigInt                @default(0)
  financialVersion     Int                   @default(0) @map("financial_version")

  @@index([operatorId], map: "ix_students_operator")
  @@map("students")
}

model Transaction {
  id                  String                @id
  studentId           String                @map("student_id")
  type                TransactionType
  amount              BigInt
  correctionDirection CorrectionDirection?  @map("correction_direction")
  reason              String?
  notes               String?
  occurredAt          DateTime              @map("occurred_at")
  createdAt           DateTime              @default(now()) @map("created_at")
  createdBy           String                @map("created_by")
  updatedAt           DateTime              @map("updated_at")
  updatedBy           String                @map("updated_by")
  revision            Int                   @default(1)
  deletedAt           DateTime?             @map("deleted_at")
  deletedBy           String?               @map("deleted_by")
  student             Student               @relation(fields: [studentId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  creator             User                  @relation("TransactionCreator", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: NoAction)
  updater             User                  @relation("TransactionUpdater", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: NoAction)
  deleter             User?                 @relation("TransactionDeleter", fields: [deletedBy], references: [id], onDelete: Restrict, onUpdate: NoAction)
  auditEvents         FinancialAuditEvent[]

  @@index([studentId, occurredAt(sort: Desc), id(sort: Desc)], map: "ix_transactions_student_history")
  @@index([studentId, deletedAt, occurredAt(sort: Desc), id(sort: Desc)], map: "ix_transactions_student_active_history")
  @@index([studentId, type, occurredAt(sort: Desc)], map: "ix_transactions_student_type_date")
  @@map("transactions")
}

model FinancialAuditEvent {
  id                  String                  @id
  commandId           String                  @unique(map: "uq_financial_audit_command") @map("command_id")
  commandPayloadHash  String                  @map("command_payload_hash")
  eventType           FinancialAuditEventType @map("event_type")
  actorId             String                  @map("actor_id")
  actorRole           Role                    @map("actor_role")
  studentId           String                  @map("student_id")
  transactionId       String?                 @map("transaction_id")
  transactionRevision Int?                    @map("transaction_revision")
  reason              String?
  beforeSnapshot      String?                 @map("before_snapshot")
  afterSnapshot       String?                 @map("after_snapshot")
  balanceBefore       BigInt?                 @map("balance_before")
  balanceAfter        BigInt?                 @map("balance_after")
  balanceDelta        BigInt?                 @map("balance_delta")
  oldOperatorId       String?                 @map("old_operator_id")
  newOperatorId       String?                 @map("new_operator_id")
  occurredAt          DateTime                @default(now()) @map("occurred_at")
  schemaVersion       Int                     @default(1) @map("schema_version")
  correlationId       String                  @map("correlation_id")
  actor               User                    @relation("FinancialAuditActor", fields: [actorId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  student             Student                 @relation(fields: [studentId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  transaction         Transaction?            @relation(fields: [transactionId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([studentId, occurredAt(sort: Desc), id(sort: Desc)], map: "ix_financial_audit_student")
  @@index([transactionId, transactionRevision], map: "ix_financial_audit_transaction_revision")
  @@map("financial_audit_events")
}
