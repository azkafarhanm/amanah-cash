# Copy this file to .env. The data/ directory is ignored by Git.
DATABASE_URL="file:./data/amanah-cash.sqlite"

# Local-only authentication bypass. The application rejects this in production.
# Set to false to exercise the real Google OAuth flow.
AUTH_DEV_MODE="true"

# Required when AUTH_DEV_MODE=false. Create a Google OAuth 2.0 Web client.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Local-only example. Generate an independent secret for every deployed environment.
# Example generator: openssl rand -base64 32
NEXTAUTH_SECRET="local-development-secret-change-before-production"

# Application origin only: no trailing path, query, or fragment.
# Local callback:      http://localhost:3000/api/auth/callback/google
# Production callback: https://cash.example.com/api/auth/callback/google
NEXTAUTH_URL="http://localhost:3000"

# Idempotent local seed and development-login identities.
# Use real Google test-account emails here when AUTH_DEV_MODE=false.
DEV_SEED_ADMIN_EMAIL="admin@amanah-cash.example"
DEV_SEED_OPERATOR_EMAIL="operator@amanah-cash.example"
DEV_SEED_STUDENT_NAME="Development Student"
