# SQLite database already migrated through migrations/002_auth_identity_and_ownership.sql.
DATABASE_URL="file:./data/amanah-cash.sqlite"

# Google OAuth 2.0 Web application credentials.
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Generate independently for every environment; minimum 32 characters.
NEXTAUTH_SECRET="replace-with-a-cryptographically-random-secret"

# Application origin only: no trailing path, query, or fragment.
# Local callback:      http://localhost:3000/api/auth/callback/google
# Production callback: https://cash.example.com/api/auth/callback/google
NEXTAUTH_URL="http://localhost:3000"
